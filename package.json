{
  "name": "raktakosh-mvp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Raktakosh — Blood Coordination Platform, Version 1.0",
  "scripts": {
    "dev": "node scripts/check-local-ports.mjs && concurrently -k -n API,WEB -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc --noEmit && vite build",
    "db:migrate": "tsx scripts/migrate-database.ts",
    "start": "tsx server/index.ts",
    "serve": "npm run build && npm run start",
    "test": "tsx --test server/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "multer": "^2.0.2",
    "mysql2": "^3.22.6",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1"
  }
}
