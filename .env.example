# Backend (Render)
NODE_ENV=development
PORT=8787
DATABASE_URL=mysql://USERNAME:PASSWORD@HOST:4000/DATABASE
DATABASE_SSL=true
# Optional: paste the TiDB CA certificate as a multiline value when your TiDB plan requires it.
TIDB_CA_CERT=
FRONTEND_ORIGIN=http://localhost:5173
SESSION_HOURS=24
STALE_AFTER_HOURS=12
DATABASE_POOL_SIZE=8
AUTO_MIGRATE=true
CSRF_SECRET=replace-with-a-long-random-secret
MFA_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key
DOCUMENT_STORAGE_MODE=local-development

# Create facility/admin accounts during the first deployment. Keep these values only in Render.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
BOOTSTRAP_REVIEWER_EMAIL=reviewer@example.com
BOOTSTRAP_REVIEWER_PASSWORD=replace-with-a-strong-reviewer-password
BOOTSTRAP_INVENTORY_EMAIL=inventory@example.com
BOOTSTRAP_INVENTORY_PASSWORD=replace-with-a-strong-inventory-password
BOOTSTRAP_STAFF=false

# Frontend (Vercel)
VITE_API_BASE_URL=http://localhost:8787
